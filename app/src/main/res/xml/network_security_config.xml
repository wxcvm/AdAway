<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Allow plain HTTP to the loopback IP for the "is server running?"
        health-check in WebServerUtils (http://127.0.0.1/internal-test).
        Without this, Android 9+ blocks cleartext to 127.0.0.1 at OS level,
        causing an IOException before the server can even be reached and the
        UI incorrectly shows "not running" even when the server is up.
    -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>

    <!--
        For the HTTPS cert-installation check (https://localhost/internal-test):
        trust both system-level and user-level CAs so the per-device certificate
        can be installed at either level and be correctly detected.
    -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">localhost</domain>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </domain-config>
</network-security-config>
